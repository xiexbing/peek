+    def popleft_queue_aware(self, n: int) -> list[KVCacheBlock]:
+        """Pop ``n`` free blocks, preferring blocks no waiting request needs.
+
+        Two-tier victim selection:
+          Tier 0 (unprotected): ``queue_ref_count == 0`` -- taken first, in
+              LRU (free-list head-to-tail) order.
+          Tier 1 (protected):   ``queue_ref_count > 0`` -- only spilled into
+              when fewer than ``n`` unprotected blocks exist, cheapest first
+              (lowest ``queue_ref_count``).
+
+        Falls back to the fast :meth:`popleft_n` path when nothing is
+        protected, so the common case pays only one extra list walk.
+        """
+        if n == 0:
+            return []
+        assert self.num_free_blocks >= n
+
+        unprotected: list[KVCacheBlock] = []
+        protected: list[KVCacheBlock] = []
+        curr = self.fake_free_list_head.next_free_block
+        while curr is not None and curr is not self.fake_free_list_tail:
+            if curr.queue_ref_count == 0:
+                unprotected.append(curr)
+            else:
+                protected.append(curr)
+            curr = curr.next_free_block
+
+        if not protected:
+            return self.popleft_n(n)
+
+        victims = unprotected[:n]
+        if len(victims) < n:
+            protected.sort(key=lambda b: b.queue_ref_count)
+            victims.extend(protected[: n - len(victims)])
+
+        for block in victims:
+            self.remove(block)
+        return victims
+
