diff --git a/python/sglang/srt/mem_cache/evict_policy.py b/python/sglang/srt/mem_cache/evict_policy.py
index dad1625..7077965 100644
--- a/python/sglang/srt/mem_cache/evict_policy.py
+++ b/python/sglang/srt/mem_cache/evict_policy.py
@@ -63,3 +63,29 @@ class SLRUStrategy(EvictionStrategy):
 
         is_protected = 1 if node.hit_count >= self.protected_threshold else 0
         return (is_protected, node.last_access_time)
+
+
+class QueueAwareStrategy(EvictionStrategy):
+    """Queue-aware eviction: protect blocks that waiting requests will reuse.
+
+    ``TreeNode.queue_ref_count`` is refreshed every scheduling step from the
+    prefixes matched by the current waiting queue (see
+    ``SchedulePolicy._update_queue_refs``). This strategy turns that signal
+    into an eviction order.
+
+    Priority Logic (smaller value = evicted earlier):
+
+    Segment 0 (Unreferenced): queue_ref_count == 0
+        No waiting request needs these blocks -- evict first, LRU order.
+    Segment 1 (Referenced): queue_ref_count > 0
+        A waiting request will reuse this prefix. Evict last, and within the
+        segment evict the cheapest-to-recompute first: smaller
+        ``queue_ref_count * num_tokens`` (few dependents, short prefix), then
+        LRU as a final tiebreaker.
+    """
+
+    def get_priority(self, node: TreeNode) -> Tuple[int, float, float]:
+        is_referenced = 1 if node.queue_ref_count > 0 else 0
+        num_tokens = len(node.key) if node.key is not None else 0
+        cost = node.queue_ref_count * num_tokens
+        return (is_referenced, cost, node.last_access_time)
