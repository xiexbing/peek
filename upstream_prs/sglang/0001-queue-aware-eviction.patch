+    # ------------------------------------------------------------------
+    # Queue-aware eviction: reference counting
+    # ------------------------------------------------------------------
+
+    def inc_queue_ref(self, node: TreeNode) -> None:
+        """Mark ``node`` and its ancestors as needed by a waiting request.
+
+        Called once per waiting request with the last node of its matched
+        prefix, so every block on the root->node path is protected from
+        eviction while the request is queued.
+        """
+        self._queue_ref_touched.append(node)
+        while node is not None and node is not self.root_node:
+            node.queue_ref_count += 1
+            node = node.parent
+
+    def reset_all_queue_refs(self) -> None:
+        """Zero ``queue_ref_count`` on every node touched since the last reset.
+
+        Called at the start of each scheduling step before re-counting from
+        the current waiting queue.
+        """
+        for node in self._queue_ref_touched:
+            while node is not None and node is not self.root_node:
+                node.queue_ref_count = 0
+                node = node.parent
+        self._queue_ref_touched = []
+
