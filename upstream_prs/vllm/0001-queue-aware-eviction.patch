+    def _update_queue_refs(self) -> None:
+        """Protect blocks that queued requests will reuse from eviction.
+
+        No-op unless queue-aware eviction is enabled. For every request in the
+        waiting queue, walk its block hashes, look up the matching cached
+        blocks, and mark them (increment ``queue_ref_count``) so
+        ``BlockPool.get_new_blocks`` evicts unneeded blocks first. Counts are
+        rebuilt from scratch every step, so protection tracks the live queue
+        with no leakage across steps.
+        """
+        block_pool = self.kv_cache_manager.block_pool
+        if not block_pool.enable_queue_aware_eviction:
+            return
+        if not self.kv_cache_manager.enable_caching or not self.waiting:
+            return
