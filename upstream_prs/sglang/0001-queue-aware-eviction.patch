+    def _update_queue_refs(self, waiting_queue: List[Req]) -> None:
+        """Refresh per-node queue reference counts from the waiting queue.
+
+        No-op unless the radix cache uses the ``queue-aware`` eviction policy.
+        For each waiting request, the last node of its matched prefix (and all
+        ancestors) is marked as referenced, so ``QueueAwareStrategy`` evicts
+        blocks that no queued request needs before touching blocks a queued
+        request will reuse. Counts are rebuilt from scratch every scheduling
+        step, so protection tracks the live queue with no leakage.
